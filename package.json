{
  "name": "@lonnycorp/lonnymq",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "repository": {
    "url": "git+https://github.com/lonnycorp/lonnymq.git"
  },
  "publishConfig": {
