    "lint": "bun eslint --max-warnings=0",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-ts": "4.2.0",
    "@types/bun": "latest",
    "@types/pg": "^8.15.4",
    "@typescript-eslint/eslint-plugin": "8.26.1",
    "@typescript-eslint/parser": "8.26.1",
    "eslint": "9.22.0",
    "pg": "^8.16.3",
    "tsdown": "^0.22.2",
    "typedoc": "^0.28.15",
    "typescript": "^5"
  }
}
